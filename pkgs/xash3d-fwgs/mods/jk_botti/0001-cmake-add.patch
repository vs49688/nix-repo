From e7153dabf229e8f402f9262d972adc44858fe170 Mon Sep 17 00:00:00 2001
From: Zane van Iperen <zane@zanevaniperen.com>
Date: Sun, 19 Apr 2026 04:06:37 +1000
Subject: [PATCH 1/2] cmake: add

---
 CMakeLists.txt | 57 ++++++++++++++++++++++++++++++++++++++++++++++++++
 waypoint.cpp   |  3 +--
 2 files changed, 58 insertions(+), 2 deletions(-)
 create mode 100644 CMakeLists.txt

diff --git a/CMakeLists.txt b/CMakeLists.txt
new file mode 100644
index 0000000..88b913d
--- /dev/null
+++ b/CMakeLists.txt
@@ -0,0 +1,57 @@
+cmake_minimum_required(VERSION 4.0)
+
+project(jk_botti)
+
+find_package(ZLIB REQUIRED)
+
+set(VER_MAJOR 0 CACHE STRING "Major Version")
+set(VER_MINOR 0 CACHE STRING "Minor Version")
+set(VER_NOTE "unknown" CACHE STRING "Version Note")
+
+add_library(jk_botti_mm MODULE
+        bot.cpp
+        bot_chat.cpp
+        bot_client.cpp
+        bot_combat.cpp
+        bot_trace.cpp
+        bot_config_init.cpp
+        bot_models.cpp
+        bot_navigate.cpp
+        bot_query_hook.cpp
+        bot_query_hook_linux.cpp
+        bot_query_hook_win32.cpp
+        bot_skill.cpp
+        bot_sound.cpp
+        bot_weapons.cpp
+        commands.cpp
+        dll.cpp
+        engine.cpp
+        h_export.cpp
+        random_num.cpp
+        safe_snprintf.cpp
+        util.cpp
+        waypoint.cpp
+)
+target_include_directories(jk_botti_mm PRIVATE
+        ./metamod
+        ./common
+        ./dlls
+        ./engine
+        ./pm_shared
+)
+target_compile_definitions(jk_botti_mm PRIVATE
+        VER_MAJOR=${VER_MAJOR}
+        VER_MINOR=${VER_MINOR}
+        VER_NOTE="${VER_NOTE}"
+)
+target_compile_options(jk_botti_mm PRIVATE
+        -Wall
+        -Wno-write-strings
+        -Wno-class-memaccess
+        -fvisibility=hidden
+        -fno-rtti
+        -fno-exceptions
+        -fno-strict-aliasing
+        -fno-strict-overflow
+)
+target_link_libraries(jk_botti_mm PRIVATE ZLIB::ZLIB)
diff --git a/waypoint.cpp b/waypoint.cpp
index 5bbbcda..27fc1d3 100644
--- a/waypoint.cpp
+++ b/waypoint.cpp
@@ -26,8 +26,7 @@
 #include "bot_weapons.h"
 #include "player.h"
 
-#define Z_PREFIX
-#include "zlib/zlib.h"
+#include "zlib.h"
 
 
 extern int m_spriteTexture;
